     for (const sector of Sectors) {\n            sector._index = sector_index++;\n        }\n        return TickingSector._ActiveSectors;\n    }\n\n    /**\n     * SNAPS coordinate to the start of a chunk boundary (..., -16, 0, 16, ...)\n     */\n    private static _snapToChunk(val: number): number {\n        return Math.floor(val / TickingSector.CHUNK_SIZE) * TickingSector.CHUNK_SIZE;\n    }\n\n    public static calculateCount(Length: number): number {\n        return Math.ceil(Length / this.MAX_AXIAL_LENGTH);\n    }\n\n    public static addSector(origin_x: number, origin_z: number, terminal_x: number, terminal_z: number): void {\n        const sector: TickingSector = new TickingSector(origin_x, origin_z, terminal_x, terminal_z);\n        \n        if (TickingSector._ActiveSectors.length >= this.MAX_ACTIVE_SECTORS) {\n            const oldest: TickingSector = TickingSector._ActiveSectors[0];\n            oldest.delete();\n        }\n        \n        sector.activate();\n        this._ActiveSectors.push(sector);\n        this._updateIndices();\n    }\n\n    /**\n     * SNAPPY COORDINATE ENGINE\n     * Manages ticking sectors around a target coordinate.\n     * Snaps to nearest neighbors within 128 blocks to ensure seamless bridging.\n     * Logic strictly adheres to 16-block chunk boundaries.\n     */\n    public static aroundCoord(coord: Coord3D): void {\n        // 1. Existing Sector Coverage Check\n        for (const sector of TickingSector._ActiveSectors) {\n            if (sector.inSector(coord)) {\n                sector.activate(); \n                return;\n            }\n        }\n\n        // 2. Default Bounds (Centered 128x128 footprint, snapped to chunks)\n        let n_ox = TickingSector._snapToChunk(coord.x - 64);\n        let n_oz = TickingSector._snapToChunk(coord.z - 64);\n        let n_tx = n_ox + 127; // 128 blocks inclusive\n        let n_tz = n_oz + 127;\n\n        // 3. Proximity Search for Neighbor Snapping\n        let nearest: TickingSector = null;\n        let min_sq_dist = 99999999;\n\n        for (const s of TickingSector._ActiveSectors) {\n            const cx = (s.origin_x + s.terminal_x) / 2;\n            const cz = (s.origin_z + s.terminal_z) / 2;\n            const dx = coord.x - cx;\n            const dz = coord.z - cz;\n            const sq_dist = (dx * dx) + (dz * dz);\n\n            if (sq_dist < min_sq_dist) {\n                min_sq_dist = sq_dist;\n                nearest = s;\n            }\n        }\n\n        // 4. Snapping Logic (Threshold: 128 blocks from center)\n        if (nearest && Math.sqrt(min_sq_dist) <= 128) {\n            const x_diff = coord.x - ((nearest.origin_x + nearest.terminal_x) / 2);\n            const z_diff = coord.z - ((nearest.origin_z + nearest.terminal_z) / 2);\n\n            if (Math.abs(x_diff) > Math.abs(z_diff)) {\n                // Snap to X-Face of neighbor (Multiples of 128 are multiples of 16, so alignment is preserved)\n                n_ox = (x_diff > 0) ? nearest.terminal_x + 1 : nearest.origin_x - 128;\n                n_tx = n_ox + 127;\n                // Inherit Neighbor Z-Alignment (Already Chunk-Aligned)\n                n_oz = nearest.origin_z;\n                n_tz = nearest.terminal_z;\n            } else {\n                // Snap to Z-Face of neighbor\n                n_oz = (z_diff > 0) ? nearest.terminal_z + 1 : nearest.origin_z - 128;\n                n_tz = n_oz + 127;\n                // Inherit Neighbor X-Alignment (Already Chunk-Aligned)\n                n_ox = nearest.origin_x;\n                n_tx = nearest.terminal_x;\n            }\n        }\n\n        TickingSector.addSector(n_ox, n_oz, n_tx, n_tz);\n    }\n\n    public static activateSector(Sector: TickingSector): TickingSector {\n        const adding_cmd: string = \"tickingarea add \" + Sector.origin_x + \" 0 \" + Sector.origin_z + \" \" + Sector.terminal_x + \" 0 \" + Sector.terminal_z + \" \" + Sector.name;\n        player.execute(adding_cmd);\n        return Sector;\n    }\n\n    public static deactivateSector(Sector: TickingSector): TickingSector {\n        const removal_cmd: string = \"tickingarea remove \" + Sector.name;\n        player.execute(removal_cmd);\n        return Sector;\n    }\n\n    public static deleteSector(Sector: TickingSector): void {\n        const sector_index: number = Sector._index;\n        this.deactivateSector(Sector);\n\n        if (sector_index !== -1) {\n            TickingSector._ActiveSectors.splice(sector_index, 1);\n            Sector._index = -1; \n            this._updateIndices();\n        }\n    }\n\n    public static clear() {\n        player.execute(\"tickingarea remove_all\");\n        this._ActiveSectors = [];\n    }\n\n    readonly origin_x: number;\n    readonly origin_z: number;\n    readonly terminal_x: number;\n    readonly terminal_z: number;\n    readonly name: string;\n    private _index: number; \n\n    constructor(\n        origin_x: number,\n        origin_z: number,\n        terminal_x: number,\n        terminal_z: number\n    ) {\n        this.name = \"ticking_sector_\" + TickingSector.SectorCount;\n        TickingSector.SectorCount++;\n        this.origin_x = origin_x;\n        this.origin_z = origin_z;\n        this.terminal_x = terminal_x;\n        this.terminal_z = terminal_z;\n        this._index = -1;\n    }\n\n    public inSector(coord: Coord3D): boolean {\n        const x_in = coord.x >= this.origin_x && coord.x <= this.terminal_x;\n        const z_in = coord.z >= this.origin_z && coord.z <= this.terminal_z;\n        return x_in && z_in;\n    }\n\n    public activate(): this {\n        TickingSector.activateSector(this);\n        return this;\n    }\n\n    public deactivate(): this {\n        TickingSector.deactivateSector(this);\n        return this;\n    }\n\n    public delete(): void {\n        TickingSector.deleteSector(this);\n    }\n\n    public get index(): number {\n        return this._index;\n    }\n}\n"]]},{"start1":23045,"length1":0,"diffs":[[1,"    